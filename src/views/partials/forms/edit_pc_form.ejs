<%
  const _inModal = (typeof inModal !== 'undefined') ? inModal : false;
  const _ids = (typeof ids !== 'undefined') ? ids : {};
  const formId = _ids.formId || 'editPcForm';
  const patrimonioId = _ids.patrimonioId || 'patrimonio';
  const setorId = _ids.setorId || 'setor';
  const specsId = _ids.specsId || 'specs';
  const _actionUrl = (typeof actionUrl !== 'undefined') ? actionUrl : (typeof id !== 'undefined' ? `/editar-pc?id=${id}` : '#');
%>


<div class="d-flex align-items-center justify-content-start mb-4">
  <% if (_inModal) { %>
  <button type="button" class="btn btn-back" data-bs-dismiss="modal" aria-label="Fechar">
    <i class="fas fa-arrow-left"></i>
  </button>
  <% } else { %>
  <a href="javascript:history.back()" class="btn btn-back">
    <i class="fas fa-arrow-left"></i>
  </a>
  <% } %>

  <h2 class="card-title mb-0 mx-auto">Editar Computador</h2>
</div>

<form id="<%= formId %>" action="<%= _actionUrl %>" method="post">
  <% if (typeof id !== 'undefined') { %>
  <input type="hidden" name="id" value="<%= id %>">
  <% } %>

  <div class="form-group">
    <label for="<%= patrimonioId %>">Numero de patrimonio do Computador</label>
    <input type="text" class="form-control" id="<%= patrimonioId %>" name="patrimonio" value="<%= (typeof patrimonio !== 'undefined' && patrimonio !== null) ? patrimonio : '' %>">
  </div>

  <div class="form-group">
    <label for="<%= setorId %>">setor</label>
    <input type="text" class="form-control" id="<%= setorId %>" name="setor" value="<%= (typeof setor !== 'undefined' && setor !== null) ? setor : '' %>">
  </div>

  <div class="form-group">
    <label for="<%= specsId %>">Descrição</label>
    <textarea class="form-control" id="<%= specsId %>" name="specs" rows='10'><%= (typeof specs !== 'undefined' && specs !== null) ? specs : '' %></textarea>
  </div>

  <hr>

  <div class="text-center">
    <button type="submit" class="btn btn-success">Enviar</button>
  </div>
</form>
<% if (_inModal) { %>
<hr>

<div class="d-flex gap-2 justify-content-center flex-wrap">
  <button type="button" class="btn btn-secondary" id="btnAddManutencaoFromEdit">
    Adicionar Manutenção
  </button>

  <button type="button" class="btn btn-warning" id="btnTransferirFromEdit">
    Transferir Unidade
  </button>
</div>
<% } %>