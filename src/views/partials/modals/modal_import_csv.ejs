<div class="modal fade" id="modalImportCsv" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-body">

        <div class="card">
          <div class="card-body text-center">
            <div class="d-flex align-items-center justify-content-start mb-4">
              <button type="button" class="btn btn-back" data-bs-dismiss="modal" aria-label="Fechar">
                <i class="fas fa-arrow-left"></i>
              </button>
              <h2 class="card-title mb-0 mx-auto">Importar Computadores</h2>
            </div>

            <form action="/importar-csv" method="post" enctype="multipart/form-data">
              <div class="form-group">
                <label for="empresaImport">Selecione a Empresa</label>
                <select class="form-select" name="empresaId" id="empresaImport" required>
                  <% (empresas || []).forEach(function(empresa) { %>
                    <option value="<%= empresa.id %>"><%= empresa.nome %></option>
                  <% }); %>
                </select>
              </div>

              <div class="form-group mt-2">
                <label for="csvFileModal">Selecione o arquivo CSV</label>
                <input type="file" class="form-control" name="csvFile" id="csvFileModal" required>
              </div>

              <hr>

              <div class="text-center">
                <button type="submit" class="btn btn-primary">Importar</button>
              </div>
            </form>

          </div>
        </div>

      </div>
    </div>
  </div>
</div>
