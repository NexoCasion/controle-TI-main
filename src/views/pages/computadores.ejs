<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Informações do Computador</title>
    <!-- Adicionando Bootstrap CSS (opcional, caso queira usar o framework para estilização) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Adicionando Font Awesome (opcional, caso queira usar os ícones) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/app.css">

    
</head>
<body>
    <header class="headerComponent">
        <%- include("./../partials/header.ejs") %>
    </header>

    <div class="container">
      
        <h1 class="mt-4 mb-4">Lista de Computadores</h1>
        <button
          type="button"
          style="font-size: .75rem;"
          class="btn btn-secondary btn-lg btn-block mb-2"
          data-bs-toggle="modal"
          data-bs-target="#modalRegisterPc"
        >
          Adicionar Computador
        </button>

        <div class="mt-3 mb-2">
          <small class="text-muted" id="totalComputadores">Computadores exibidos: 0 / Total: 0</small>
        </div>


        
        <!-- Dropdown para filtrar por empresa -->
        <div class="mb-3">
            <label for="selectEmpresa" class="form-label">Filtrar por Empresa:</label>
            <select id="selectEmpresa" class="form-select">
                <option value="">Todas as Empresas</option>
                <% empresas.forEach(function(empresa) { %>
                    <option value="<%= empresa.id %>"><%= empresa.nome %></option>
                <% }); %>
            </select>
            <div class="mb-3">
                <label for="searchInput" class="form-label">Pesquisar:</label>
                <input id="searchInput" class="form-control" type="text"
                placeholder="Digite patrimônio, especificações ou empresa...">
            </div>

        </div>
        <!-- Tabela de computadores -->
        <table class="table">
            <thead>
              
              <th scope="col" style="cursor:pointer" onclick="ordenarPor('patrimonio')" data-sort-col="0">
                Patrimônio <span class="sort-indicator"></span>
              </th>
              <th scope="col" style="cursor:pointer" onclick="ordenarPor('specs')" data-sort-col="1">
                Especificações <span class="sort-indicator"></span>
              </th>
              <th scope="col" style="cursor:pointer" onclick="ordenarPor('setor')" data-sort-col="2">
                Setor <span class="sort-indicator"></span>
              </th>
              <th scope="col" style="cursor:pointer" onclick="ordenarPor('empresa')" data-sort-col="3">
                Empresa <span class="sort-indicator"></span>
              </th>
              <th scope="col">Ações</th>
            </thead>


            <tbody id="tableBody"></tbody>
            </table>
            </div>

    <!-- Adicionando Bootstrap JS (opcional, caso queira usar funcionalidades como modals ou dropdowns) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Adicionando script personalizado para filtrar computadores por empresa -->
     <%- include("../partials/modals/modal_register_pc", { empresas: empresas }) %>
     <%- include("../partials/modals/modal_edit_pc") %>
     <%- include("../partials/modals/modal_register_manutencao") %>
     <%- include("../partials/modals/modal_transfer_pc", { empresas: empresas }) %>
     <%- include("../partials/modals/modal_import_csv", { empresas: empresas }) %>
      


    <script>
document.addEventListener("DOMContentLoaded", function () {
  const selectEmpresa = document.getElementById("selectEmpresa");
  const searchInput = document.getElementById("searchInput");
  const tableBody = document.getElementById("tableBody");
  const totalComputadoresEl = document.getElementById("totalComputadores");


  // Se algum elemento não existir, para aqui e mostra no console
  if (!selectEmpresa || !searchInput || !tableBody) {
    console.error("IDs não encontrados. Verifique selectEmpresa/searchInput/tableBody no HTML.");
    return;
  }

  let currentComputadores = [];
  let direcaoOrdenacao = {};
  let currentOrder = { coluna: null, asc: true };

  function atualizarContadores(total, visiveis) {
  if (totalComputadoresEl) {
    totalComputadoresEl.textContent = `Computadores exibidos: ${visiveis} / Total: ${total}`;
  }
}
  // Importar CSV (fecha Register PC -> abre Import CSV)
const btnOpenImport = document.getElementById("btnOpenImportCsvFromRegister");
if (btnOpenImport) {
  btnOpenImport.addEventListener("click", () => {
    switchModal("modalRegisterPc", "modalImportCsv", () => {
      // opcional: se você estiver filtrando uma empresa na tela, já preseleciona no import
      const filtro = document.getElementById("selectEmpresa");
      const empresaId = filtro ? filtro.value : "";
      const empresaImport = document.getElementById("empresaImport");
      if (empresaImport && empresaId) empresaImport.value = empresaId;
    });
  });
}



  async function carregarComputadores(empresaId) {
    try {
      const response = await fetch(`/computadores-by-empresa?empresaId=${empresaId || ""}`);
      const computadores = await response.json();
      currentComputadores = Array.isArray(computadores) ? computadores : [];
      aplicarFiltrosEOrdenacao();
    } catch (error) {
      console.log(`Erro ao buscar computadores: ${error}`);
    }
  }

  function aplicarFiltrosEOrdenacao() {
    const termo = (searchInput.value || "").trim().toLowerCase();

    // total sempre do conjunto carregado (empresa selecionada ou todas)
    const total = currentComputadores.length;

    // filtra pelo termo
    let filtrados = currentComputadores.filter((c) => {
      const patrimonio = (c.patrimonio || "").toString().toLowerCase();
      const specs = (c.specs || "").toString().toLowerCase();
      const empresa = (c.empresa?.nome || "").toString().toLowerCase();
      const setor = (c.setor || "").toString().toLowerCase();
      

      const texto = ` ${patrimonio} ${specs} ${empresa} ${setor}`;
      return termo === "" || texto.includes(termo);
    });

    // ordena se tiver coluna selecionada
    if (currentOrder.coluna !== null) {
      const colunaIndex = currentOrder.coluna;
      const asc = currentOrder.asc;

      filtrados.sort((a, b) => {
        let valorA = "";
        let valorB = "";

        // mapeia colunas: 0=patrimonio, 1=specs, 2=setor, 3=empresa
if (colunaIndex === 0) {
  valorA = (a.patrimonio ?? "").toString();
  valorB = (b.patrimonio ?? "").toString();
} else if (colunaIndex === 1) {
  valorA = (a.specs ?? "").toString();
  valorB = (b.specs ?? "").toString();
} else if (colunaIndex === 2) {
  valorA = (a.setor ?? "").toString();
  valorB = (b.setor ?? "").toString();
} else if (colunaIndex === 3) {
  valorA = (a.empresa?.nome ?? "").toString();
  valorB = (b.empresa?.nome ?? "").toString();
}


        // tenta número
        const numA = parseFloat(valorA.replace(/\D/g, ""));
        const numB = parseFloat(valorB.replace(/\D/g, ""));
        const ambosNumeros = !isNaN(numA) && !isNaN(numB) && valorA !== "" && valorB !== "";

        if (ambosNumeros) return asc ? numA - numB : numB - numA;

        valorA = valorA.trim().toLowerCase();
        valorB = valorB.trim().toLowerCase();
        return asc ? valorA.localeCompare(valorB) : valorB.localeCompare(valorA);
      });
    }

    renderizarComputadores(filtrados);
    atualizarContadores(total, filtrados.length);
  }

  function renderizarComputadores(computadores) {
    tableBody.innerHTML = "";

    computadores.forEach((computador) => {
      const row = `
  <tr>
    <td>${computador.patrimonio ?? ""}</td>
    <td>${computador.specs ?? "Sem descrição"}</td>
    <td>${computador.setor ?? ""}</td>
    <td>${computador.empresa?.nome ?? "Sem empresa"}</td>
    <td>
      <div class="btn-group m-2 align-items-center" role="group">
        <button
          type="button"
          class="btn btn-primary btn-sm btn-edit"
          data-id="${computador.id}"
          data-patrimonio="${(computador.patrimonio ?? "").toString().replace(/"/g, '&quot;')}"
          data-setor="${(computador.setor ?? "").toString().replace(/"/g, '&quot;')}"
          data-specs="${(computador.specs ?? "").toString().replace(/"/g, '&quot;')}"
          data-bs-toggle="modal"
          data-bs-target="#modalEditPc"
          data-empresa-id="${computador.empresaId ?? ''}"
        >
          <i class="fas fa-pencil-alt"></i> Editar
        </button>

        <a href="/ver-pc?id=${computador.id}" class="btn m-1 btn-info btn-sm">
          <i class="fas fa-eye"></i> Ver
        </a>
      </div>
    </td>
  </tr>
`;


      tableBody.innerHTML += row;
    });
  }

  function ordenarTabela(colunaIndex) {
    if (currentOrder.coluna === colunaIndex) {
      currentOrder.asc = !currentOrder.asc;
    } else {
      currentOrder.coluna = colunaIndex;
      currentOrder.asc = true;
    }
    aplicarFiltrosEOrdenacao();
    atualizarSetasOrdenacaoComputadores();

  }
function atualizarSetasOrdenacaoComputadores() {
  const ths = document.querySelectorAll("th[data-sort-col]");
  ths.forEach(th => {
    const span = th.querySelector(".sort-indicator");
    if (!span) return;

    span.innerHTML = "";
    const col = parseInt(th.getAttribute("data-sort-col"), 10);

    if (col === currentOrder.coluna) {
      span.innerHTML = currentOrder.asc
        ? '<i class="fas fa-sort-up" style="margin-left:6px;"></i>'
        : '<i class="fas fa-sort-down" style="margin-left:6px;"></i>';
    }
  });
}

  function ordenarPor(tipo) {
  const map = { patrimonio: 0, specs: 1, setor: 2, empresa: 3 };


  if (map[tipo] !== undefined) ordenarTabela(map[tipo]);
}
    // Clique no botão "Editar" (event delegation)
  tableBody.addEventListener("click", (e) => {
    const btn = e.target.closest(".btn-edit");
    if (!btn) return;

    const id = btn.getAttribute("data-id");
    const patrimonio = btn.getAttribute("data-patrimonio") || "";
    const setor = btn.getAttribute("data-setor") || "";
    const specs = btn.getAttribute("data-specs") || "";
    const empresaId = btn.getAttribute("data-empresa-id");
    window.__editPcCtx = { computadorId: id, empresaId: empresaId };


    const form = document.getElementById("formEditPc");
    const inPatrimonio = document.getElementById("editPatrimonio");
    const inSetor = document.getElementById("editSetor");
    const inSpecs = document.getElementById("editSpecs");

    if (!form || !inPatrimonio || !inSetor || !inSpecs) return;

    form.action = `/editar-pc?id=${id}`;
    inPatrimonio.value = patrimonio;
    inSetor.value = setor;
    inSpecs.value = specs;
  });

// ====== BOTÕES DO MODAL EDITAR + HELPERS (Bootstrap 5 beta3 compat) ======
const btnAddMan = document.getElementById("btnAddManutencaoFromEdit");
const btnTransf = document.getElementById("btnTransferirFromEdit");

function ensureModal(modalId) {
  const el = document.getElementById(modalId);
  if (!el || !window.bootstrap || !bootstrap.Modal) return null;
  return bootstrap.Modal.getInstance(el) || new bootstrap.Modal(el);
}

function openModal(modalId) {
  const inst = ensureModal(modalId);
  if (inst) inst.show();
  return inst;
}

// Fecha um modal e só depois abre o outro (evita “backdrop” duplicado)
function switchModal(fromId, toId, beforeShow) {
  const fromEl = document.getElementById(fromId);
  const fromInst = ensureModal(fromId);

  if (!fromEl || !fromInst) {
    if (typeof beforeShow === "function") beforeShow();
    openModal(toId);
    return;
  }

  fromEl.addEventListener(
    "hidden.bs.modal",
    () => {
      if (typeof beforeShow === "function") beforeShow();
      openModal(toId);
    },
    { once: true }
  );

  fromInst.hide();
}

// Adicionar Manutenção (fecha Editar -> abre Manutenção com prefill)
if (btnAddMan) {
  btnAddMan.addEventListener("click", () => {
    if (!window.__editPcCtx || !window.__editPcCtx.computadorId) {
      console.warn("Contexto do PC não encontrado. Clique em EDITAR primeiro.");
      return;
    }

    window.__prefManutencao = {
      empresaId: window.__editPcCtx.empresaId,
      computadorId: window.__editPcCtx.computadorId,
    };

    switchModal("modalEditPc", "modalRegisterManutencao");
  });
}

// Transferir Unidade (fecha Editar -> abre Transferência com hidden inputs)
if (btnTransf) {
  btnTransf.addEventListener("click", () => {
    if (!window.__editPcCtx || !window.__editPcCtx.computadorId) {
      console.warn("Contexto do PC não encontrado. Clique em EDITAR primeiro.");
      return;
    }

    switchModal("modalEditPc", "modalTransferPc", () => {
      const inputPc = document.getElementById("transferComputadorId");
      const inputOrigem = document.getElementById("transferEmpOrigemId");
      const selectDestino = document.getElementById("transferEmpDestinoId");

      if (inputPc) inputPc.value = window.__editPcCtx.computadorId;
      if (inputOrigem) inputOrigem.value = window.__editPcCtx.empresaId ?? "";
      if (selectDestino) selectDestino.value = "";
    });
  });
}



  // expõe pro onclick do <th>
  window.ordenarTabela = ordenarTabela;
  window.ordenarPor = ordenarPor;

  selectEmpresa.addEventListener("change", function () {
    carregarComputadores(this.value);
  });

  searchInput.addEventListener("input", aplicarFiltrosEOrdenacao);

  // carrega tudo ao abrir
  carregarComputadores("");

});
</script>



</body>
</html>
