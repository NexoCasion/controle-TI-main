<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ver Manutenção</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
</head>

<body>
  <header class="headerComponent">
    <%- include("../partials/header.ejs") %>
  </header>

  <% if (alert) { %>
    <script>alert('<%= alert %>');</script>
  <% } %>

  <div class="container">
    <h1 class="mt-4 mb-4">Informações da Manutenção</h1>

    <!-- “Título forte” igual ao Ver PC -->
    <h2 class=" mb-2">
      Manutenção #<%= manutencao.id %>
      <% if (manutencao?.computador?.status) { %>
        <span class="badge bg-danger ms-2">PC CONDENADO</span>
      <% } %>
    </h2>

    <!-- Card principal (mesma linguagem do Ver PC) -->
    <div class="card p-3 mb-3" style="border:0;">
      <div class="row g-3 text-start">
        <div class="col-md-3">
          <div class="text-muted" style="font-size:.85rem;font-weight:700;">Entrada</div>
          <div style="font-weight:700;">
            <span class="js-dt" data-iso="<%= manutencao.dataEntrada || '' %>">
                <%= manutencao.dataEntrada ? manutencao.dataEntrada : '-' %>
            </span>
            </div>

        </div>

        <div class="col-md-3">
        <div class="text-muted" style="font-size:.85rem;font-weight:700;">Saída</div>
         <div style="font-weight:700;">
            <% if (manutencao.dataSaida) { %>
                <span class="js-dt" data-iso="<%= manutencao.dataSaida || '' %>">
                <%= manutencao.dataSaida %>
                </span>
            <% } else { %>
                Em andamento
            <% } %>
            </div>

        </div>

        <div class="col-md-6">
          <div class="text-muted" style="font-size:.85rem;font-weight:700;">Descrição</div>
          <div style="font-weight:700;">
            <%= manutencao.descricao ? manutencao.descricao : '-' %>
          </div>
        </div>

        <div class="col-md-4">
          <div class="text-muted" style="font-size:.85rem;font-weight:700;">Computador</div>
          <div style="font-weight:700;">
            <% if (manutencao?.computador) { %>
              <%= manutencao.computador.patrimonio %>
            <% } else { %>
              Não possui numero de Patrimonio
            <% } %>
          </div>
        </div>

        <div class="col-md-4">
          <div class="text-muted" style="font-size:.85rem;font-weight:700;">Local</div>
          <div style="font-weight:700;">
            <%= manutencao?.computador?.setor ? manutencao.computador.setor : '-' %>
          </div>
        </div>

        <div class="col-md-4">
          <div class="text-muted" style="font-size:.85rem;font-weight:700;">Pertence à</div>
          <div style="font-weight:700;">
            <%= manutencao?.computador?.empresa?.nome ? manutencao.computador.empresa.nome : '-' %>
          </div>
        </div>

        <div class="col-12">
          <div class="text-muted" style="font-size:.85rem;font-weight:700;">Specs</div>
          <div class="text-muted">
            <%= manutencao?.computador?.specs ? manutencao.computador.specs : '-' %>
          </div>
        </div>
      </div>

      <!-- Ações (igual estilo clean) -->
      <div class="d-flex gap-2 flex-wrap mt-3">
        <a class="btn btn-outline-secondary btn-sm" href="/manutencoes">
          <i class="fas fa-arrow-left"></i> Voltar para Manutenções
        </a>

        <% if (manutencao?.computador?.id) { %>
          <a class="btn btn-primary btn-sm" href="/ver-pc?id=<%= manutencao.computador.id %>">
            <i class="fas fa-desktop"></i> Ver PC
          </a>
        <% } %>
      </div>
    </div>

    <!-- Se você tiver “itens”/histórico da manutenção, mostra aqui -->
    <h5 class="mb-2">Histórico de Procedimentos
    </h5>

    <% const itensSafe = (typeof manutencoes !== 'undefined' && manutencoes) ? manutencoes : []; %>
<% if (itensSafe.length) { %>

      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>#</th>
              <th>Descrição</th>
              <th>Data</th>
            </tr>
          </thead>
          <tbody>
            <% itensSafe.forEach((item, idx) => { %>

              <tr>
                <td><%= idx + 1 %></td>
                <td><%= item.descricao || '-' %></td>
               <td>
                <span class="js-dt" data-iso="<%= (item.data || item.dataEntrada || item.createdAt || '') %>">
                    <%= item.data || item.dataEntrada || item.createdAt || '-' %>
                </span>
                </td>

              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="text-muted" style="padding:10px 0;">
        Nenhum item adicional para esta manutenção.
      </div>
    <% } %>

  </div>
  <script>
  function formatDateTimeBR(value) {
    if (!value) return "";
    const d = new Date(value);
    if (Number.isNaN(d.getTime())) return value; // se não for ISO, mantém como veio
    return d.toLocaleString("pt-BR", {
      day: "2-digit",
      month: "2-digit",
      year: "numeric",
      hour: "2-digit",
      minute: "2-digit"
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".js-dt").forEach((el) => {
      const iso = (el.getAttribute("data-iso") || "").trim();
      if (!iso) return;
      el.textContent = formatDateTimeBR(iso);
    });
  });
    </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
