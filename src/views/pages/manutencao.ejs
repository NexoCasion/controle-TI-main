<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ver Manutenção</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
</head>

<body>
  <header class="headerComponent">
    <%- include("../partials/header.ejs") %>
  </header>

  <% if (alert) { %>
  <script>
    alert('<%= alert %>');
  </script>
  <% } %>

  <div class="container maintenance-page">
    <a href="javascript:history.back()" class="btn btn-back">
      <i class="fas fa-arrow-left"></i>
    </a>
    <h1 class="mt-4 mb-4 text-center">Informações da Manutenção</h1>





    <!-- Card principal -->

    <div class="card p-3 mb-4" style="border:0;">
      <div class="row g-3 justify-content-center  text-start">
        <div class="maint-titlebar mb-3">
          <h2 class="pc-title mb-0">
            Manutenção #<%= manutencao.id %>
            <% if (manutencao?.computador?.status) { %>
            <span class="badge bg-danger ms-2">PC CONDENADO</span>
            <% } %>
          </h2>

          <% if (manutencao.dataSaida) { %>
          <span class="maint-finalizada">
            <i class="fas fa-check-circle"></i> Finalizada
          </span>
          <% } %>
        </div>
        <div class="col-md-4">
          <div class="meta-label text-center">Computador</div>
          <div class="meta-value text-center">
            <% if (manutencao?.computador) { %>
            <%= manutencao.computador.patrimonio %>
            <% } else { %>
            Não possui número de Patrimônio
            <% } %>
          </div>
        </div>
        <div class="col-md-4">
          <div class="meta-label text-center">Entrada</div>
          <div class="meta-value text-center">
            <span class="js-dt" data-iso="<%= manutencao.dataEntrada || '' %>">
              <%= manutencao.dataEntrada ? manutencao.dataEntrada : '-' %>
            </span>
          </div>
        </div>

        <div class="col-md-4">
          <div class="meta-label text-center">Saída</div>
          <div class="meta-value text-center">
            <% if (manutencao.dataSaida) { %>
            <span class="js-dt" data-iso="<%= manutencao.dataSaida || '' %>">
              <%= manutencao.dataSaida %>
            </span>
            <% } else { %>
            Em andamento
            <% } %>
          </div>
        </div>

        <div class="col-md-4">
          <div class="meta-label text-center">Local</div>
          <div class="meta-value text-center">
            <%= manutencao?.computador?.setor ? manutencao.computador.setor : '-' %>
          </div>
        </div>

        <div class="col-md-4">
          <div class="meta-label text-center">Pertence à</div>
          <div class="meta-value text-center">
            <%= manutencao?.computador?.empresa?.nome ? manutencao.computador.empresa.nome : '-' %>
          </div>
        </div>
        <div class="col-md-4">
          <div class="meta-label text-center">Descrição</div>
          <div class="meta-value text-center">
            <%= manutencao.descricao ? manutencao.descricao : '-' %>
          </div>
        </div>
        <div class="col-12">
          <div class="meta-label text-center">Specs</div>
          <div class="text-muted text-center">
            <%= (manutencao?.computador?.specs_override ? manutencao.computador.specs_override : (manutencao?.computador?.specs || '-')) %>
          </div>
        </div>
      </div>
    </div>

    <!-- Botões Voltar / Ver PC (centralizados) -->
    <div class="maintenance-nav">
      <a class="btn btn-outline-secondary btn-sm" href="/manutencoes">
        <i class="fas fa-arrow-left"></i> Voltar para Manutenções
      </a>

      <% if (manutencao?.computador?.id) { %>
      <a class="btn btn-primary btn-sm" href="/ver-pc?id=<%= manutencao.computador.id %>">
        <i class="fas fa-desktop"></i> Ver PC
      </a>
      <% } %>
    </div>
    <!-- Histórico -->
    <h1 class="mt-4 mb-3">Histórico de Procedimentos</h1>
    <!-- Botões de ações (centralizados, acima do histórico) -->
    <% if (!manutencao.dataSaida) { %>
    <div class="maintenance-actions mb-3 align-items-center justify-content-center">


      <a class="btn btn-secondary btn-sm" href="/encerrar-manutencao?id=<%= manutencao.id %>" onclick="return confirm('Tem certeza que deseja FECHAR esta manutenção?');">
        <i class="fas fa-check"></i> Fechar manutenção
      </a>


      <button type="button" class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#modalAddProcedimento">
        <i class="fas fa-plus"></i> Adicionar procedimento
      </button>
      <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#modalCondenarMaquina">
        <i class="fas fa-ban"></i> Condenar máquina
      </button>
    </div>
    <% } else { %>

    <% } %>



    <% const itensSafe = (typeof manutencoes !== 'undefined' && manutencoes) ? manutencoes : []; %>
    <% if (itensSafe.length) { %>
    <div class="table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th>#</th>
            <th>Tipo</th>
            <th>Descrição</th>
            <th>Material</th>
            <th>Data</th>
            <th>Ações</th>
          </tr>
        </thead>

        <tbody>
          <% itensSafe.forEach((item, idx) => { %>
          <tr>
            <td><%= idx + 1 %></td>

            <td>
              <span class="badge bg-secondary"><%= item.tipo || '-' %></span>
            </td>

            <td><%= item.descricao || '-' %></td>

            <td style="max-width: 340px;">
              <small class="text-muted"><%= item.material_snapshot || '-' %></small>
            </td>

            <td>
              <span class="js-dt" data-iso="<%= (item.dataEntrada || item.createdAt || '') %>">
                <%= item.dataEntrada || item.createdAt || '-' %>
              </span>
            </td>

            <td>
              <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalDetalhesProcedimento" data-tipo="<%= (item.tipo || '') %>" data-desc="<%= (item.descricao || '').replace(/\"/g, '&quot;') %>" data-snap="<%= (item.material_snapshot || '').replace(/\"/g, '&quot;') %>" data-antes="<%= (item.specs_antes || '').replace(/\"/g, '&quot;') %>" data-depois="<%= (item.specs_depois || '').replace(/\"/g, '&quot;') %>">
                Detalhes
              </button>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="text-muted" style="padding:10px 0;">
      Nenhum item adicional para esta manutenção.
    </div>
    <% } %>
  </div>

  <!-- Script de formatação de datas -->
  <script>
    function formatDateTimeBR(value) {
      if (!value) return "";
      const d = new Date(value);
      if (Number.isNaN(d.getTime())) return value;
      return d.toLocaleString("pt-BR", {
        day: "2-digit",
        month: "2-digit",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit"
      });
    }

    document.addEventListener("DOMContentLoaded", () => {
      document.querySelectorAll(".js-dt").forEach((el) => {
        const iso = (el.getAttribute("data-iso") || "").trim();
        if (!iso) return;
        el.textContent = formatDateTimeBR(iso);
      });
    });
  </script>

  <!-- Modal: Adicionar Procedimento -->
  <div class="modal fade" id="modalAddProcedimento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <form class="modal-content" id="formAddProcedimento">
        <div class="modal-header">
          <h5 class="modal-title">Adicionar procedimento</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>

        <div class="modal-body">
          <input type="hidden" name="manutencaoId" value="<%= manutencao.id %>">

          <% const specsFinal = (manutencao?.computador?.specs_override ? manutencao.computador.specs_override : (manutencao?.computador?.specs || '')); %>
          <input type="hidden" id="specsBase" value="<%- (specsFinal || '').replace(/\"/g, '&quot;') %>">

          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Tipo de procedimento</label>
              <select class="form-select" name="tipo" id="tipoProcedimento" required>
                <option value="" selected disabled>Selecione...</option>
                <option value="TROCA_PECA">Troca de peça</option>
                <option value="LIMPEZA">Limpeza</option>
                <option value="MANUT_SIMPLES">Manutenção simples</option>
              </select>
            </div>

            <div class="col-12">
              <label class="form-label">Descrição</label>
              <textarea class="form-control" name="descricao" rows="3" required placeholder="Ex: Troca de fonte, limpeza, reinstalação do Windows..."></textarea>
              <small class="text-muted d-block mt-2">
                Isso vai aparecer no “Histórico de Procedimentos”.
              </small>
            </div>

            <!-- BLOCO: TROCA DE PEÇA -->
            <div class="col-12" id="blocoTrocaPeca" style="display:none;">
              <div class="card p-3" style="border:1px solid #eee;">
                <div class="row g-3">
                  <div class="col-md-4">
                    <label class="form-label">Tipo de peça</label>
                    <select class="form-select" id="tipoPeca" name="tipoPeca">
                      <option value="" selected disabled>Selecione...</option>
                    </select>
                    <small class="text-muted">Carregado de Materiais</small>
                  </div>

                  <div class="col-md-5">
                    <label class="form-label">Material disponível</label>
                    <select class="form-select" name="materialId" id="materialId">
                      <option value="" selected disabled>Selecione o tipo primeiro...</option>
                    </select>
                    <small class="text-muted" id="infoDisponivel"></small>
                  </div>

                  <div class="col-md-3">
                    <label class="form-label">Quantidade</label>
                    <input class="form-control" type="number" name="quantidade" id="quantidade" min="1" value="1">
                  </div>

                  <div class="col-12">
                    <label class="form-label">Editar Specs (vai salvar em specs_override)</label>
                    <textarea class="form-control" name="specs_depois" id="specsDepois" rows="3"></textarea>
                    <small class="text-muted">
                      Começa com as specs atuais (override se existir). Você edita a string livre.
                    </small>
                  </div>
                </div>
              </div>
            </div>

            <!-- Para LIMPEZA/MANUT_SIMPLES, não precisa de material nem specs_depois -->
          </div>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary" id="btnSalvarProcedimento">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: Condenar Máquina -->
  <div class="modal fade" id="modalCondenarMaquina" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <form class="modal-content" method="POST" action="/condenar-maquina">
        <div class="modal-header">
          <h5 class="modal-title">Condenar máquina</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>

        <div class="modal-body">
          <input type="hidden" name="manutencaoId" value="<%= manutencao.id %>">

          <div class="alert alert-warning mb-3">
            <b>Atenção:</b> condenar é irreversível. O PC será marcado como condenado e a manutenção será encerrada.
          </div>

          <label class="form-label">Motivo</label>
          <textarea class="form-control" name="motivo" rows="3" required placeholder="Ex: Placa-mãe queimada, custo inviável, sem peças..."></textarea>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-danger">Condenar</button>
        </div>
      </form>
    </div>
  </div>
  <!-- Modal: Detalhes do Procedimento -->
  <div class="modal fade" id="modalDetalhesProcedimento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Detalhes do procedimento</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>

        <div class="modal-body">
          <div class="mb-2"><strong>Tipo:</strong> <span id="detTipo"></span></div>
          <div class="mb-2"><strong>Descrição:</strong> <span id="detDesc"></span></div>
          <div class="mb-3"><strong>Material:</strong> <span id="detSnap"></span></div>

          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Specs antes</label>
              <textarea class="form-control" id="detAntes" rows="3" readonly></textarea>
            </div>
            <div class="col-12">
              <label class="form-label">Specs depois</label>
              <textarea class="form-control" id="detDepois" rows="3" readonly></textarea>
            </div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // helpers
    async function fetchJson(url, opts) {
      const res = await fetch(url, opts);
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data?.error || 'Erro na requisição');
      return data;
    }

    document.addEventListener("DOMContentLoaded", async () => {
      const form = document.getElementById('formAddProcedimento');
      const tipoProcedimento = document.getElementById('tipoProcedimento');
      const blocoTrocaPeca = document.getElementById('blocoTrocaPeca');
      const tipoPeca = document.getElementById('tipoPeca');
      const materialId = document.getElementById('materialId');
      const quantidade = document.getElementById('quantidade');
      const specsDepois = document.getElementById('specsDepois');
      const specsBase = document.getElementById('specsBase');
      const infoDisponivel = document.getElementById('infoDisponivel');
      const btnSalvar = document.getElementById('btnSalvarProcedimento');
      let isSubmittingProcedimento = false;
      // ✅ FIX 1: habilita/desabilita o bloco de troca de peça
      function setTrocaPecaEnabled(enabled) {
        blocoTrocaPeca.style.display = enabled ? 'block' : 'none';

        // habilita/desabilita campos
        tipoPeca.disabled = !enabled;
        materialId.disabled = !enabled;
        quantidade.disabled = !enabled;
        specsDepois.disabled = !enabled;

        // required só quando troca peça
        tipoPeca.required = enabled;
        materialId.required = enabled;
        quantidade.required = enabled;
      }

      // começa desativado
      setTrocaPecaEnabled(false);
      // preenche textarea specs com specs atuais
      if (specsDepois && specsBase) {
        specsDepois.value = specsBase.value || '';
      }

      // 1) carregar tipos de peça ao abrir a página (ou ao selecionar troca)
      async function carregarTipos() {
        const tipos = await fetchJson('/materiais-tipos');
        tipoPeca.innerHTML = '<option value="" selected disabled>Selecione...</option>';
        tipos.forEach((t) => {
          const opt = document.createElement('option');
          opt.value = t;
          opt.textContent = t;
          tipoPeca.appendChild(opt);
        });
      }

      // 2) carregar materiais disponíveis conforme tipo escolhido
      async function carregarMateriaisPorTipo(tipo) {
        materialId.innerHTML = '<option value="" selected disabled>Carregando...</option>';
        infoDisponivel.textContent = '';

        const list = await fetchJson(`/materiais?tipo=${encodeURIComponent(tipo)}&somenteDisponivel=1`);
        materialId.innerHTML = '<option value="" selected disabled>Selecione...</option>';

        if (!list.length) {
          const opt = document.createElement('option');
          opt.value = '';
          opt.textContent = 'Nenhum material disponível';
          opt.disabled = true;
          materialId.appendChild(opt);
          return;
        }

        list.forEach((m) => {
          const opt = document.createElement('option');
          opt.value = m.id;
          opt.textContent = `${m.material} (${m.marca || '-'}) — Disp: ${m.quantidade_disponivel}`;
          opt.dataset.disponivel = m.quantidade_disponivel;
          materialId.appendChild(opt);
        });
      }

      // Toggle bloco troca peça
      tipoProcedimento.addEventListener('change', async () => {
        const v = tipoProcedimento.value;

        if (v === 'TROCA_PECA') {
          setTrocaPecaEnabled(true);

          await carregarTipos();

          // reset
          tipoPeca.value = '';
          materialId.innerHTML = '<option value="" selected disabled>Selecione o tipo primeiro...</option>';
          quantidade.value = 1;
          infoDisponivel.textContent = '';

          // specs base
          specsDepois.value = specsBase.value || '';
        } else {
          // ✅ FIX 1: desativa e limpa tudo do bloco
          setTrocaPecaEnabled(false);

          tipoPeca.value = '';
          materialId.value = '';
          quantidade.value = 1;
          specsDepois.value = '';
          infoDisponivel.textContent = '';
        }
      });

      tipoPeca.addEventListener('change', async () => {
        const tipo = tipoPeca.value;
        if (!tipo) return;
        await carregarMateriaisPorTipo(tipo);
      });

      materialId.addEventListener('change', () => {
        const opt = materialId.options[materialId.selectedIndex];
        const disp = Number(opt?.dataset?.disponivel || 0);
        infoDisponivel.textContent = disp ? `Disponível: ${disp}` : '';
        // limita max da quantidade
        if (disp > 0) {
          quantidade.max = disp;
          if (Number(quantidade.value) > disp) quantidade.value = disp;
        }
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        // 🔒 FIX 4 — bloqueio real contra duplo submit
        if (isSubmittingProcedimento) return;
        isSubmittingProcedimento = true;

        btnSalvar.disabled = true;

        try {
          const fd = new FormData(form);
          const payload = Object.fromEntries(fd.entries());

          // se troca peça, valida campos extras
          if (payload.tipo === 'TROCA_PECA') {
            if (!payload.materialId) throw new Error('Selecione um material.');
            const qtd = Number(payload.quantidade || 1);
            if (!qtd || qtd <= 0) throw new Error('Quantidade inválida.');
            payload.quantidade = qtd;

            // specs_depois obrigatório na prática (vai o que estiver no textarea)
            payload.specs_depois = payload.specs_depois || '';
          } else {
            // limpa campos que não devem ir
            delete payload.materialId;
            delete payload.quantidade;
            delete payload.specs_depois;
          }

          await fetchJson('/add-item-manutencao', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload),
          });

          // recarrega a página pra atualizar histórico e specs exibida (simples por enquanto)
          window.location.reload();
        } catch (err) {
          alert(err.message || 'Erro ao salvar procedimento.');
        } finally {
          btnSalvar.disabled = false;
          isSubmittingProcedimento = false;
        }

      });

    });
  </script>
  <script>
    const modalDet = document.getElementById('modalDetalhesProcedimento');

    if (modalDet) {
      modalDet.addEventListener('show.bs.modal', function(event) {
        const btn = event.relatedTarget;
        if (!btn) return;

        document.getElementById('detTipo').textContent = btn.getAttribute('data-tipo') || '-';
        document.getElementById('detDesc').textContent = btn.getAttribute('data-desc') || '-';
        document.getElementById('detSnap').textContent = btn.getAttribute('data-snap') || '-';
        document.getElementById('detAntes').value = btn.getAttribute('data-antes') || '';
        document.getElementById('detDepois').value = btn.getAttribute('data-depois') || '';
      });
    }
  </script>
</body>

</html>