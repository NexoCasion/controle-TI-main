<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Computador</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/app.css">
<body>
    <%- include('../main') %>
    <%- include("./../partials/header.ejs") %>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <a href="/register-manutencao" class="btn btn-primary">Adicionar Manutenção</a>
                        <button type="button" class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#transferModal">Transferir Computador</button>
                    </div>
                </div>
                <div class="card">
                    <div class="card-body text-center">
                        <%- include('../partials/forms/edit_pc_form', {
  inModal: false,
  actionUrl: `/editar-pc?id=${id}`,
  id: id,
  patrimonio: patrimonio,
  setor: setor,
  specs: specs
}) %>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="transferModal" tabindex="-1" role="dialog" aria-labelledby="transferModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="transferModalLabel">Transferir Computador</h5>
                    <button type="button" class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#transferModal">

                </div>
                <div class="modal-body">
                    <form id="transferForm" action="/transferir" method="post">
                        <input type="hidden" name="computador" value="<%= id %>">
                        <input type="hidden" name="emp_origem" value="<%= empresa.id %>">
                        <div class="form-group">
                            <label for="empresa">Selecione a Empresa</label>
                            <select class="form-control" id="empresa" name="emp_destino">
                                <% empresas.forEach(function(empresa) { %>
                                    <option value="<%= empresa.id %>"><%= empresa.nome %></option>
                                <% }); %>
                            </select>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    <button type="submit" form="transferForm" class="btn btn-primary">Transferir</button>
                </div>
            </div>
        </div>
    </div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta3/dist/js/bootstrap.bundle.min.js"></script>


</body>
</html>
